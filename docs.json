{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "TickDB Docs",
  "defaultLanguage": "zh-Hans",
  "redirects": [
    {
      "source": "/",
      "destination": "/zh-Hans/index"
    }
  ],
  "colors": {
    "primary": "#0D9373",
    "light": "#07C983",
    "dark": "#0D9373"
  },
  "favicon": "/logo.png",
  "api": {
    "mdx": {
      "server": "https://api.tickdb.ai",
      "auth": {
        "method": "key",
        "name": "X-API-Key"
      }
    }
  },
  "navigation": {
    "languages": [
      {
        "language": "zh-Hans",
        "tabs": [
          {
            "tab": "文档",
            "groups": [
              {
                "group": "介绍",
                "pages": [
                  "zh-Hans/index"
                ]
              },
              {
                "group": "入门指南",
                "pages": [
                  "zh-Hans/quick-start",
                  "zh-Hans/pricing",
                  "zh-Hans/release-notes"
                ]
              },
              {
                "group": "REST API",
                "pages": [
                  {
                    "group": "通用行情接口",
                    "expanded": true,
                    "pages": [
                      "zh-Hans/rest/api_symbols",
                      "zh-Hans/rest/api_ticker",
                      "zh-Hans/rest/api_kline",
                      "zh-Hans/rest/api_kline_latest",
                      "zh-Hans/rest/api_depth",
                      "zh-Hans/rest/api_trades",
                      "zh-Hans/rest/api_intervals"
                    ]
                  },
                  {
                    "group": "股票市场接口",
                    "expanded": true,
                    "pages": [
                      "zh-Hans/rest/api_intraday",
                      "zh-Hans/rest/api_stock_info",
                      "zh-Hans/rest/api_trading_sessions",
                      "zh-Hans/rest/api_trade_days",
                      "zh-Hans/rest/api_calc_index",
                      "zh-Hans/rest/api_capital_flow"
                    ]
                  }
                ]
              },
              {
                "group": "WebSocket 文档",
                "pages": [
                  "zh-Hans/websocket/websocket_quickstart",
                  "zh-Hans/websocket/websocket_subscribe"
                ],
                "asyncapi": {
                  "source": "/asyncapi.json",
                  "directory": "zh-Hans/websocket/websocket_playground"
                }
              },
              {
                "group": "参考",
                "pages": [
                  "zh-Hans/data-specification",
                  "zh-Hans/errors"
                ]
              }
            ]
          }
        ]
      },
